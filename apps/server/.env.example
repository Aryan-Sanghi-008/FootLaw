# Server Configuration
PORT=3001
NODE_ENV=development

# Database
# For local development: mongodb://localhost:27017/footlaw
# For Docker: mongodb://mongo:27017/footlaw
MONGODB_URI=mongodb://localhost:27017/footlaw

# Authentication
# Change these to long random strings in production!
JWT_SECRET=footlaw_dev_secret_change_in_production
JWT_REFRESH_SECRET=footlaw_dev_refresh_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (for Match Engine / Caching)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=*

# Externals
GOOGLE_CLIENT_ID=your_id_here
GOOGLE_CLIENT_SECRET=your_secret_here
